{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Conduit",
  "version": "0.13.0",
  "identifier": "com.conduit.tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Conduit",
        "width": 1100,
        "height": 720,
        "minWidth": 980,
        "minHeight": 600,
        "theme": "Dark",
        "titleBarStyle": "Overlay",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "publisher": "Ooozzy",
    "homepage": "https://ooozzy.com",
    "category": "DeveloperTool",
    "copyright": "© 2026 Ooozzy (Uzair Hayat)",
    "shortDescription": "Run multiple real Claude Code terminals across projects.",
    "longDescription": "Conduit is a native-feeling desktop app for running multiple real `claude` CLI sessions across your projects — each in a live terminal, with a file tree, git graph, and per-session to-dos driven by Claude Code hooks.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFM0VGNzFCQTM1QkQ3Q0EKUldUSzExdWpHL2MrSG9qcTJtU3FDWitPWGFwei8vZkZIN1Vpa1dyY1lSYi9Ib2M4ekdzNERSclMK",
      "endpoints": [
        "https://github.com/uziiuzair/conduit/releases/latest/download/latest.json"
      ]
    }
  }
}
